{
  "version": 2,
  "outputRoot": ".docs/planning/concepts",
  "orchestration": {
    "concurrency": 5,
    "validationSubfolder": "validation",
    "screenshotsSubfolder": "validation/screenshots",
    "requireValidation": true,
    "requireExternalInspiration": true,
    "uniquenessThreshold": 0.55
  },
  "passesPerStyle": 2,
  "requiredViews": [
    "dashboard",
    "projects",
    "project-workspace",
    "kanban",
    "whiteboard",
    "schema-planner",
    "directory-tree",
    "ideas",
    "ai-chat",
    "settings"
  ],
  "styles": [
    {
      "id": "signal-brutalist",
      "label": "Signal Brutalist",
      "notes": "Hard-edged poster systems, anti-polish typography, zero-softness component geometry.",
      "layoutArchetypes": ["slab-grid", "stamp-ops-ledger"],
      "passVariants": [
        { "pass": 1, "variantSeed": "slab-grid-ruleset-v2" },
        { "pass": 2, "variantSeed": "stamp-ops-ledger-v2" }
      ]
    },
    {
      "id": "aurora-glass",
      "label": "Aurora Glass",
      "notes": "Translucent spatial UI with atmospheric depth and premium command-surface polish.",
      "layoutArchetypes": ["floating-dock-window", "orbital-rail-prism"],
      "passVariants": [
        { "pass": 1, "variantSeed": "floating-dock-window-v2" },
        { "pass": 2, "variantSeed": "orbital-rail-prism-v2" }
      ]
    },
    {
      "id": "ledger-editorial",
      "label": "Ledger Editorial",
      "notes": "Publication-grade storytelling shells with strong reading hierarchy and low-chrome controls.",
      "layoutArchetypes": ["broadsheet-columns", "tabbed-legal-notebook"],
      "passVariants": [
        { "pass": 1, "variantSeed": "broadsheet-columns-v2" },
        { "pass": 2, "variantSeed": "tabbed-legal-notebook-v2" }
      ]
    },
    {
      "id": "industrial-terminal",
      "label": "Industrial Terminal",
      "notes": "Operator-heavy control environments, telemetry density, and machine-instrument metaphors.",
      "layoutArchetypes": ["crt-command-console", "scada-wallboard-grid"],
      "passVariants": [
        { "pass": 1, "variantSeed": "crt-command-console-v2" },
        { "pass": 2, "variantSeed": "scada-wallboard-grid-v2" }
      ]
    },
    {
      "id": "playful-clay",
      "label": "Playful Clay",
      "notes": "Expressive, tactile, characterful systems with playful interaction language.",
      "layoutArchetypes": ["sticker-workbench", "comic-panel-workspace"],
      "passVariants": [
        { "pass": 1, "variantSeed": "sticker-workbench-v2" },
        { "pass": 2, "variantSeed": "comic-panel-workspace-v2" }
      ]
    }
  ]
}
