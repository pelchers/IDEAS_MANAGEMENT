{
  "concept": {
    "domain": "graphic-design",
    "style": "globe-3d",
    "pass": 1,
    "title": "3D Interactive Globe — Pass 1",
    "description": "Wireframe Earth globe with glowing city dots and animated connection arcs representing IDEA-MANAGEMENT global user connections. Three.js WebGL rendering with OrbitControls, auto-rotation, and hover tooltips."
  },
  "palette": {
    "primary": "#3B82F6",
    "secondary": "#10B981",
    "background": "#030712",
    "surface": "#111827",
    "text": "#F9FAFB"
  },
  "library": {
    "name": "Three.js",
    "version": "0.170.0",
    "source": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js",
    "modules": ["three", "OrbitControls"],
    "loadMethod": "importmap"
  },
  "files": [
    {
      "path": "index.html",
      "role": "entry",
      "description": "HTML shell with importmap for Three.js ES modules, header, controls panel, and footer"
    },
    {
      "path": "style.css",
      "role": "styles",
      "description": "Grid layout, dark theme, controls, tooltip, loading overlay, responsive breakpoints"
    },
    {
      "path": "app.js",
      "role": "application",
      "description": "Three.js scene setup, globe wireframe, city dots, connection arcs, star field, animation loop, raycasting hover"
    },
    {
      "path": "README.md",
      "role": "documentation",
      "description": "Concept overview, palette table, feature list, file structure, local run instructions"
    }
  ],
  "scene": {
    "globe": {
      "radius": 200,
      "segments": [48, 32],
      "wireframeOpacity": 0.08,
      "latitudeRings": [-60, -30, 0, 30, 60]
    },
    "cities": {
      "count": 15,
      "dotRadius": 2.8,
      "pulseAnimation": true,
      "hoverHighlight": true,
      "tooltipOnHover": true
    },
    "connections": {
      "totalPairs": 25,
      "curveType": "QuadraticBezierCurve3",
      "segments": 64,
      "dashAnimation": true,
      "densityControl": true
    },
    "stars": {
      "count": 2000,
      "distributionRadius": [1400, 2000]
    },
    "camera": {
      "fov": 50,
      "position": [0, 80, 520],
      "minDistance": 280,
      "maxDistance": 900
    }
  },
  "interactivity": {
    "autoRotate": {
      "default": true,
      "speed": 0.001,
      "axis": "Y",
      "toggleable": true
    },
    "orbitControls": {
      "damping": true,
      "dampingFactor": 0.06,
      "rotateSpeed": 0.5,
      "panEnabled": false
    },
    "hover": {
      "raycasting": true,
      "targetObjects": "cityMeshes",
      "tooltipContent": ["cityName", "userCount"],
      "highlightEffect": "scale + color shift"
    },
    "densitySlider": {
      "min": 0,
      "max": 100,
      "default": 70,
      "unit": "percent"
    },
    "cameraReset": true
  },
  "performance": {
    "targetFPS": 60,
    "pixelRatioCap": 2,
    "antialiasing": true,
    "renderLoop": "requestAnimationFrame"
  },
