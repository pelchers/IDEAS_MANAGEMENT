# ============================================================================
# APP
# ============================================================================
NODE_ENV="development"
# For production: NODE_ENV="production"

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/idea_management?schema=public"

# ============================================================================
# AUTH
# ============================================================================
AUTH_COOKIE_SECURE="false"
# For production: AUTH_COOKIE_SECURE="true" (requires HTTPS)
AUTH_SESSION_TTL_SECONDS="900"
AUTH_REFRESH_TTL_SECONDS="2592000"

# ============================================================================
# ADMIN BOOTSTRAP
# ============================================================================
# Used to create the initial admin account via: pnpm --filter web admin:bootstrap
ADMIN_BOOTSTRAP_KEY="change-me"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
# For production: use strong unique values and rotate after first bootstrap

# ============================================================================
# STRIPE (Billing)
# ============================================================================
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ============================================================================
# AI — OpenRouter (primary) + OpenAI (server fallback)
# ============================================================================
# OpenRouter OAuth PKCE — register at https://openrouter.ai/settings/keys
OPENROUTER_CLIENT_ID=""
NEXT_PUBLIC_OPENROUTER_CLIENT_ID=""
# OPENROUTER_CLIENT_SECRET is optional (public PKCE clients don't need it)
# OPENROUTER_CLIENT_SECRET=""

# Session encryption key (used to encrypt stored API keys)
SESSION_SECRET="change-me-in-production"

# Server-side OpenAI fallback (used only if user has no OpenRouter key configured)
OPENAI_API_KEY="sk-..."

