# =============================================================================
# IDEA-MANAGEMENT — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables marked (required) MUST be set for the application to start.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Pooled connection URL for application queries (required)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct connection URL for Prisma migrations (required)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication Secrets
# -----------------------------------------------------------------------------
# Secret used for signing session tokens (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="change-me-to-a-random-64-byte-hex-string"

# Secret used for signing refresh tokens (required)
REFRESH_SECRET="change-me-to-a-different-random-64-byte-hex-string"

# Session TTL in seconds (default: 900 = 15 minutes)
AUTH_SESSION_TTL_SECONDS=900

# Refresh token TTL in seconds (default: 2592000 = 30 days)
AUTH_REFRESH_TTL_SECONDS=2592000

# Set to "true" in production to enforce Secure cookie flag (required in production)
AUTH_COOKIE_SECURE="true"

# -----------------------------------------------------------------------------
# Admin Bootstrap
# -----------------------------------------------------------------------------
# Email for the initial admin account (required)
ADMIN_EMAIL="admin@yourdomain.com"
# One-time bootstrap key for admin account creation (required)
ADMIN_BOOTSTRAP_KEY="change-me-use-once-then-rotate"

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
# Stripe secret key (required for billing)
STRIPE_SECRET_KEY="sk_live_..."
# Stripe webhook signing secret (required for billing)
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe price IDs for subscription plans (required for billing)
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."
# Legacy env var name alias (used in webhook handler)
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."

# -----------------------------------------------------------------------------
# AI / OpenAI
# -----------------------------------------------------------------------------
# OpenAI API key for AI chat features (required for AI features)
OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public URL of the web application (required)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# -----------------------------------------------------------------------------
# Redis (Optional — for rate limiting and caching)
# -----------------------------------------------------------------------------
# Upstash Redis REST URL (optional, falls back to in-memory)
# REDIS_URL="https://your-instance.upstash.io"
# REDIS_TOKEN="your-upstash-token"

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
